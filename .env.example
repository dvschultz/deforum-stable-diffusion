# Copy this file to `.env` and fill in your fal.ai API key.
# Generation runs on the hosted Z-Image Turbo model by default; the key is read from
# the environment (a real FAL_KEY env var always takes precedence over this file).
# `.env` is gitignored so your key is never committed.
FAL_KEY=your-fal-api-key-here

# --- Optional model / backend selection (env fallbacks; root settings win) ----
# DEFORUM_MODEL: z-image (default) | krea2 (Krea 2 Turbo)
# DEFORUM_MODEL=z-image
# DEFORUM_BACKEND: fal (default, hosted) | local (experimental, needs a CUDA GPU)
# DEFORUM_BACKEND=fal

# --- Local backend only -------------------------------------------------------
# Skip re-download by pointing at downloaded weight dirs:
# ZIMAGE_LOCAL_PATH=/path/to/Z-Image-Turbo
# KREA2_LOCAL_PATH=/path/to/Krea-2-Turbo
# Weight-only quantization (memory lever). nf4 is effectively required to fit Krea 2
# (12.9B) on a single 24GB GPU; unset = full bf16. int8 | nf4 | bf16(off).
# ZIMAGE_QUANTIZE=nf4
